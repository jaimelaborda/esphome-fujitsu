# Copy to secrets.yaml and fill in your own values. secrets.yaml is gitignored.
wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"
ap_password: "fallback-ap-password"

# Home Assistant API encryption key (generate at https://esphome.io/components/api.html)
api_encryption_key: "generate-a-32-byte-base64-key"

# OTA update password
ota_password: "choose-an-ota-password"
